[base]
salt = "AnyTokenYouWanted"
port = 7777
timeit_enable = false
exposed_url = "http://127.0.0.1:7777"

# ani player API key (random 16-char string for security)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(12))"
ani_api_key = ""  # e.g. "aBc123XyZ789qRs"

[tgApi]
api_id = int_app_id_from_tg
api_hash = "api_hash_from_tg"

[proxy]
enable = false
proxy_type = "socks5"
addr = "172.25.32.1"
port = 7890

[web]
enable = true
name = "default"
port = 2000

[[clients]]
name = "default"
interval = 0.1
whitelist_chat = [123456789, -1001234567890]
[base]
salt = "AnyTokenYouWanted"
port = 7777
timeit_enable = false
exposed_url = "http://127.0.0.1:7777"

# Permanent sign for ani player RSS subscription (optional)
# If not set, will auto-generate from first available client
# permanent_sign_client = "default"  # client name for generating permanent sign
# permanent_sign_years = 10  # sign validity in years (default: 10)

[tgApi]
api_id = int_app_id_from_tg
api_hash = "api_hash_from_tg"

[proxy]
enable = false
proxy_type = "socks5"
addr = "172.25.32.1"
port = 7890

[web]
enable = true
name = "default"
port = 2000

[[clients]]
name = "default"
interval = 0.1
whitelist_chat = [123456789, -1001234567890]